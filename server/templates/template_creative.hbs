<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{name}} — {{title}}</title>
<meta name="description" content="{{bio}}">
<style>
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:#0a0a0a;color:#fafafa;font-family:system-ui,-apple-system,'Segoe UI',sans-serif;line-height:1.6;min-height:100vh}
a{color:#fafafa;text-decoration:none;transition:opacity 0.2s}
a:hover{opacity:0.7}
.container{max-width:1100px;margin:0 auto;padding:80px 32px}
.hero{padding:100px 0 80px;text-align:center}
.hero-name{font-size:clamp(48px,10vw,96px);font-weight:900;letter-spacing:-0.06em;line-height:0.95;text-transform:uppercase}
.hero-title{font-size:clamp(16px,3vw,24px);color:#71717a;margin-top:16px;font-weight:300;letter-spacing:0.15em;text-transform:uppercase}
.hero-location{font-size:13px;color:#52525b;margin-top:12px;font-family:monospace}
.hero-links{display:flex;justify-content:center;gap:24px;margin-top:32px}
.hero-links a{font-size:12px;font-family:monospace;color:#71717a;letter-spacing:0.1em;text-transform:uppercase;padding-bottom:4px;border-bottom:1px solid rgba(255,255,255,0.15)}
.bio-section{padding:64px 0;max-width:700px;margin:0 auto;text-align:center;font-size:18px;color:#a1a1aa;line-height:1.9;font-weight:300}
.divider{width:60px;height:1px;background:rgba(255,255,255,0.15);margin:0 auto}
.section{padding:64px 0}
.section-label{font-size:11px;font-family:monospace;color:#52525b;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:40px}
.skills-list{display:flex;flex-direction:column;gap:4px}
.skills-list span{font-size:15px;color:#71717a;font-weight:300;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.04)}
.project-grid{display:grid;gap:20px}
.project-item{background:#111;border:1px solid rgba(255,255,255,0.06);border-radius:8px;overflow:hidden}
.project-img{width:100%;height:240px;background:#1a1a1a;display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:700;color:rgba(255,255,255,0.08);text-transform:uppercase;letter-spacing:0.1em}
.project-info{padding:24px}
.project-info h3{font-size:20px;font-weight:700;margin-bottom:8px}
.project-info p{font-size:14px;color:#71717a;line-height:1.7;margin-bottom:12px}
.project-meta{display:flex;gap:12px;flex-wrap:wrap}
.project-meta a{font-size:11px;font-family:monospace;color:#52525b;border-bottom:1px solid rgba(255,255,255,0.1);padding-bottom:2px}
.exp-item{padding:24px 0;border-bottom:1px solid rgba(255,255,255,0.04)}
.exp-role{font-size:16px;font-weight:600}
.exp-company{font-size:14px;color:#52525b;font-family:monospace}
.exp-date{font-size:12px;color:#3f3f46;font-family:monospace;margin-top:4px}
.exp-desc{font-size:14px;color:#71717a;margin-top:8px;line-height:1.7}
.footer{padding:40px 0;text-align:center;font-size:11px;font-family:monospace;color:#27272a}
@media(max-width:600px){.container{padding:48px 16px}.hero{padding:60px 0 48px}.hero-name{font-size:40px}}
{{#if customCss}}
{{{customCss}}}
{{/if}}
</style>
</head>
<body>
<div class="container">
  <div class="hero" data-section="name-title">
    <h1 class="hero-name">{{name}}</h1>
    <p class="hero-title">{{title}}</p>
    {{#if location}}<p class="hero-location">{{location}}</p>{{/if}}
    <div class="hero-links">
      {{#if email}}<a href="mailto:{{email}}">Email</a>{{/if}}
      {{#if linkedin}}<a href="{{linkedin}}" target="_blank">LinkedIn</a>{{/if}}
      {{#if github}}<a href="{{github}}" target="_blank">GitHub</a>{{/if}}
    </div>
  </div>

  {{#if bio}}
  <div class="bio-section" data-section="bio">{{bio}}</div>
  <div class="divider"></div>
  {{/if}}

  {{#if skills.length}}
  <section class="section" data-section="skills">
    <h2 class="section-label">Expertise</h2>
    <div class="skills-list">
      {{#each skills}}<span>{{this}}</span>{{/each}}
    </div>
  </section>
  {{/if}}

  {{#if projects.length}}
  <section class="section" data-section="projects">
    <h2 class="section-label">Selected Work</h2>
    <div class="project-grid">
      {{#each projects}}
      <div class="project-item">
        <div class="project-img">{{this.title}}</div>
        <div class="project-info">
          <h3>{{this.title}}</h3>
          {{#if this.description}}<p>{{this.description}}</p>{{/if}}
          <div class="project-meta">
            {{#if this.githubUrl}}<a href="{{this.githubUrl}}" target="_blank">Source</a>{{/if}}
            {{#if this.liveUrl}}<a href="{{this.liveUrl}}" target="_blank">View Live</a>{{/if}}
          </div>
        </div>
      </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{#if experience.length}}
  <section class="section" data-section="experience">
    <h2 class="section-label">Experience</h2>
    {{#each experience}}
    <div class="exp-item">
      <div class="exp-role">{{this.role}}</div>
      <div class="exp-company">{{this.company}}</div>
      <div class="exp-date">{{this.startDate}} — {{#if this.isPresent}}Present{{else}}{{this.endDate}}{{/if}}</div>
      {{#if this.description}}<p class="exp-desc">{{this.description}}</p>{{/if}}
    </div>
    {{/each}}
  </section>
  {{/if}}

  <footer class="footer" data-section="education">
    {{#if education}}
    <p>{{education.degree}} · {{education.institution}} · {{education.graduationYear}}</p>
    {{/if}}
    <p style="margin-top:16px">Built with Portify · {{currentYear}}</p>
  </footer>
</div>

<script>
(function(){
  var pid='{{portfolioId}}';
  var sid='s_'+Math.random().toString(36).substr(2,9);
  function track(type,data){
    fetch('/api/analytics/'+type,{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify(Object.assign({portfolioId:pid,sessionId:sid},data))
    }).catch(function(){});
  }
  track('pageview',{referrer:document.referrer,userAgent:navigator.userAgent,timestamp:new Date().toISOString()});
  var sections=document.querySelectorAll('[data-section]');
  var observer=new IntersectionObserver(function(entries){
    entries.forEach(function(entry){
      if(entry.isIntersecting){
        var start=Date.now();
        var el=entry.target;
        var check=setInterval(function(){
          if(!el.getBoundingClientRect || el.getBoundingClientRect().top>window.innerHeight||el.getBoundingClientRect().bottom<0){
            clearInterval(check);
            track('section-view',{section:el.getAttribute('data-section'),timeSpentMs:Date.now()-start});
          }
        },1000);
        setTimeout(function(){clearInterval(check);track('section-view',{section:el.getAttribute('data-section'),timeSpentMs:Date.now()-start});},30000);
      }
    });
  },{threshold:0.3});
  sections.forEach(function(s){observer.observe(s);});
})();
</script>
</body>
</html>
