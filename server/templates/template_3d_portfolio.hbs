<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{metaDescription}}" />
  <meta property="og:title" content="{{metaTitle}}" />
  <meta property="og:description" content="{{metaDescription}}" />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="{{avatarImage}}" />
  <title>{{metaTitle}}</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
  <style>
    /* Global text visibility guarantee */
    h1, h2, h3, h4, h5, h6 {
      color: inherit;
    }

    body,
    .page {
      background-color: #000000 !important;
      color: #ffffff !important;
    }

    .hero,
    .skills-section,
    #projects,
    #experience,
    #contact,
    footer {
      color: #ffffff !important;
      mix-blend-mode: normal !important;
    }

    .hero *,
    .skills-section *,
    #projects *,
    #experience *,
    #contact *,
    footer * {
      color: #ffffff !important;
      -webkit-text-fill-color: #ffffff !important;
    }

    .about {
      background: #0a0a0a !important;
      color: #ffffff !important;
    }

    .about * {
      color: #ffffff !important;
      -webkit-text-fill-color: #ffffff !important;
    }

    canvas {
      z-index: 0 !important;
      pointer-events: none !important;
    }

    #hero-canvas {
      position: fixed !important;
      top: 0;
      left: 0;
      width: 100vw !important;
      height: 100vh !important;
      z-index: 0 !important;
      pointer-events: none !important;
    }

    section > *:not(canvas),
    .section-shell > *:not(canvas),
    .about > *:not(canvas),
    .contact > *:not(canvas) {
      position: relative;
      z-index: 5;
    }

    :root {
      --bg: #000000;
      --panel: rgba(255, 255, 255, 0.04);
      --panel-strong: rgba(255, 255, 255, 0.08);
      --border: rgba(255, 255, 255, 0.11);
      --border-strong: rgba(255, 255, 255, 0.18);
      --text: #ffffff;
      --muted: rgba(255, 255, 255, 0.68);
      --muted-soft: rgba(255, 255, 255, 0.42);
      --shadow: 0 26px 60px rgba(0, 0, 0, 0.46);
      --font-display: "Inter", "Segoe UI", sans-serif;
      --font-body: "Inter", "Segoe UI", sans-serif;
      --font-mono: "IBM Plex Mono", "SFMono-Regular", Consolas, monospace;
      --content-width: min(1180px, calc(100vw - 64px));
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      min-height: 100vh;
      background:
        radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.05), transparent 28%),
        radial-gradient(circle at 80% 0%, rgba(255, 255, 255, 0.035), transparent 24%),
        linear-gradient(180deg, #040404 0%, #000000 100%);
      color: var(--text);
      font-family: var(--font-body);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    body.cursor-enabled,
    body.cursor-enabled a,
    body.cursor-enabled button {
      cursor: none;
    }

    a {
      color: inherit;
    }

    button,
    input,
    textarea {
      font: inherit;
    }

    #scroll-progress {
      position: fixed;
      top: 0;
      left: 0;
      z-index: 60;
      height: 1px;
      width: 0;
      background: #ffffff;
      box-shadow: 0 0 14px rgba(255, 255, 255, 0.36);
      transform-origin: left center;
    }

    #cursor {
      position: fixed;
      left: 0;
      top: 0;
      z-index: 90;
      width: 12px;
      height: 12px;
      border: 1px solid rgba(255, 255, 255, 0.9);
      border-radius: 999px;
      pointer-events: none;
      opacity: 0;
      transform: translate(-50%, -50%);
      mix-blend-mode: difference;
      transition: width 0.2s ease, height 0.2s ease, opacity 0.2s ease, background 0.2s ease;
    }

    #cursor.active {
      width: 40px;
      height: 40px;
      background: rgba(255, 255, 255, 0.08);
    }

    .page {
      position: relative;
    }

    .section-nav {
      position: fixed;
      left: 24px;
      top: 50%;
      z-index: 55;
      display: flex;
      flex-direction: column;
      gap: 12px;
      transform: translateY(-50%);
    }

    .section-nav a {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      color: var(--muted-soft);
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .nav-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.48);
      background: transparent;
      transition: transform 0.25s ease, background 0.25s ease, border-color 0.25s ease;
      flex: 0 0 auto;
    }

    .section-nav a span:last-child {
      opacity: 0;
      transform: translateX(-4px);
      transition: opacity 0.25s ease, transform 0.25s ease;
      white-space: nowrap;
    }

    .section-nav a:hover span:last-child,
    .section-nav a.active span:last-child {
      opacity: 1;
      transform: translateX(0);
    }

    .section-nav a.active {
      color: var(--text);
    }

    .section-nav a.active .nav-dot {
      background: #ffffff;
      border-color: #ffffff;
      transform: scale(1.22);
    }

    .hero,
    .section,
    .footer {
      position: relative;
    }

    .hero {
      min-height: 100vh;
      isolation: isolate;
      mix-blend-mode: normal !important;
    }

    #hero-canvas,
    .section-particles {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
    }

    .hero::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(0, 0, 0, 0.18) 0%, rgba(0, 0, 0, 0.48) 100%),
        radial-gradient(circle at 50% 50%, transparent 0%, rgba(0, 0, 0, 0.36) 80%);
      z-index: 1;
      pointer-events: none;
    }

    .hero-overlay {
      position: relative;
      z-index: 10;
      min-height: 100vh;
      width: var(--content-width);
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      gap: 14px;
      padding: 64px 0 96px;
      color: #ffffff !important;
    }

    .hero-label,
    .section-kicker,
    .meta-row,
    .project-tech span,
    .timeline-range,
    .contact-links a,
    .footer {
      font-family: var(--font-mono);
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .hero-label {
      font-size: 0.7rem;
      color: #ffffff !important;
      -webkit-text-fill-color: #ffffff !important;
    }

    .hero-name {
      margin: 0;
      max-width: 980px;
      font-size: clamp(3.5rem, 9vw, 5rem);
      line-height: 0.92;
      letter-spacing: -0.06em;
      font-family: var(--font-display);
      font-weight: 800;
      text-transform: uppercase;
      color: #ffffff !important;
      -webkit-text-fill-color: #ffffff !important;
      text-shadow: none;
      mix-blend-mode: normal;
    }

    .hero-role {
      margin: 0;
      max-width: 760px;
      font-size: 0.94rem;
      color: #ffffff !important;
      -webkit-text-fill-color: #ffffff !important;
      font-family: var(--font-mono);
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .hero-scroll-hint {
      position: absolute;
      left: 50%;
      bottom: 42px;
      transform: translateX(-50%);
      font-size: 0.72rem;
      color: #ffffff !important;
      -webkit-text-fill-color: #ffffff !important;
      font-family: var(--font-mono);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      animation: pulseHint 2.2s ease-in-out infinite;
    }

    @keyframes pulseHint {
      0%, 100% { opacity: 0.28; transform: translateX(-50%) translateY(0); }
      50% { opacity: 1; transform: translateX(-50%) translateY(-8px); }
    }

    .section {
      width: var(--content-width);
      margin: 0 auto;
      padding: 132px 0;
    }

    .section-shell {
      position: relative;
      z-index: 2;
    }

    .section-kicker {
      display: inline-flex;
      margin-bottom: 22px;
      font-size: 0.72rem;
      color: var(--muted-soft);
    }

    .section-title {
      margin: 0 0 18px;
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 0.95;
      letter-spacing: -0.05em;
      font-family: var(--font-display);
      font-weight: 700;
      text-transform: uppercase;
    }

    .section-intro {
      margin: 0;
      max-width: 680px;
      color: var(--muted);
      line-height: 1.8;
      font-size: 1rem;
    }

    .panel {
      background: var(--panel);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
    }

    .about {
      display: grid;
      grid-template-columns: minmax(260px, 340px) minmax(0, 1fr);
      gap: 52px;
      align-items: center;
      overflow: visible !important;
      border-radius: 28px;
      padding: 56px;
      background: #0a0a0a !important;
      color: #ffffff !important;
    }

    .about-avatar-frame {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 360px;
    }

    .about-avatar {
      width: min(300px, 80vw);
      aspect-ratio: 1 / 1;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.15);
      box-shadow: 0 0 40px rgba(255, 255, 255, 0.06);
      object-fit: cover;
      animation: floatAvatar 6s ease-in-out infinite;
    }

    @keyframes floatAvatar {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-12px); }
    }

    .about-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 28px;
    }

    .about-bio {
      overflow: visible !important;
      display: block !important;
      -webkit-line-clamp: unset !important;
      -webkit-box-orient: unset !important;
      max-height: none !important;
      height: auto !important;
    }

    .meta-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.03);
      color: #ffffff !important;
      font-size: 0.78rem;
    }

    .skills-grid {
      margin-top: 34px;
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      min-height: 120px;
      align-items: center;
      perspective: 1400px;
      position: relative;
      z-index: 10;
    }

    .badge {
      position: relative;
      z-index: 10;
      border: 1px solid rgba(255, 255, 255, 0.16);
      background: rgba(255, 255, 255, 0.04);
      color: #ffffff !important;
      -webkit-text-fill-color: #ffffff !important;
      padding: 12px 18px;
      border-radius: 999px;
      font-family: var(--font-mono);
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: transform 0.28s ease, opacity 0.28s ease, border-color 0.28s ease, background 0.28s ease;
      transform-style: preserve-3d;
      cursor: pointer;
      opacity: 1 !important;
      visibility: visible !important;
      pointer-events: auto;
      white-space: nowrap;
      user-select: none;
    }

    .badge:hover,
    .badge.active {
      transform: scale(1.12) translateZ(22px);
      border-color: rgba(255, 255, 255, 0.42);
      background: rgba(255, 255, 255, 0.1);
    }

    .skills-grid.dimmed .badge {
      opacity: 0.3;
    }

    .skills-grid.dimmed .badge.active {
      opacity: 1;
    }

    #skill-tooltip {
      margin-top: 18px;
      min-height: 24px;
      color: var(--muted);
      font-family: var(--font-mono);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-size: 0.72rem;
    }

    .projects-grid {
      margin-top: 34px;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 28px;
    }

    .project-card {
      position: relative;
      height: 420px;
      perspective: 1000px;
      cursor: pointer;
      transition: transform 0.18s ease;
    }

    .card-inner {
      position: relative;
      width: 100%;
      height: 100%;
      transform-style: preserve-3d;
      transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .project-card.flipped .card-inner {
      transform: rotateY(180deg);
    }

    .card-face {
      position: absolute;
      inset: 0;
      border-radius: 26px;
      overflow: hidden;
      backface-visibility: hidden;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      isolation: isolate;
    }

    .card-front {
      position: relative;
      z-index: 2;
      background:
        linear-gradient(180deg, rgba(0, 0, 0, 0) 20%, rgba(0, 0, 0, 0.82) 100%),
        radial-gradient(circle at top right, rgba(255, 255, 255, 0.12), transparent 36%),
        #070707;
    }

    .card-front img,
    .project-fallback {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .card-front img {
      object-fit: cover;
      filter: grayscale(1) contrast(1.08);
    }

    .project-fallback {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 34px;
      background:
        radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.14), transparent 30%),
        radial-gradient(circle at 84% 0%, rgba(255, 255, 255, 0.08), transparent 22%),
        linear-gradient(140deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.01));
    }

    #projects .project-display-title {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 1rem 1.2rem;
      font-size: clamp(1.8rem, 5vw, 3.5rem);
      font-weight: 900;
      color: rgba(255, 255, 255, 0.06) !important;
      -webkit-text-fill-color: rgba(255, 255, 255, 0.06) !important;
      letter-spacing: -0.02em;
      line-height: 1;
      pointer-events: none;
      z-index: 1;
      overflow: hidden;
      text-transform: uppercase;
    }

    .project-fallback span {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      color: var(--muted-soft);
      text-transform: uppercase;
      margin-bottom: 14px;
    }

    .project-fallback strong {
      font-size: 2.2rem;
      line-height: 0.9;
      text-transform: uppercase;
      max-width: 240px;
    }

    .card-front-overlay {
      position: absolute;
      inset: auto 0 0;
      padding: 28px;
      z-index: 2;
      background: linear-gradient(180deg, rgba(0, 0, 0, 0.02) 0%, rgba(0, 0, 0, 0.86) 100%);
    }

    .card-front-overlay h3 {
      margin: 0;
      font-size: 1.1rem;
      font-weight: 600;
      color: #ffffff !important;
      line-height: 1;
      text-transform: uppercase;
      letter-spacing: -0.04em;
      position: relative;
      z-index: 3;
    }

    .card-back {
      transform: rotateY(180deg);
      z-index: 2;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 26px;
      background:
        radial-gradient(circle at top right, rgba(255, 255, 255, 0.08), transparent 28%),
        #0a0a0a;
    }

    .card-back h4 {
      margin: 0 0 12px;
      font-size: 0.78rem;
      color: var(--muted-soft);
      font-family: var(--font-mono);
      letter-spacing: 0.16em;
      text-transform: uppercase;
      font-weight: 500;
    }

    .card-back p {
      margin: 0;
      color: var(--muted);
      line-height: 1.8;
      font-size: 0.98rem;
    }

    .project-tech {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 18px;
    }

    .project-tech span {
      border: 1px solid rgba(255, 255, 255, 0.14);
      padding: 8px 10px;
      border-radius: 999px;
      font-size: 0.66rem;
      color: var(--muted);
    }

    .project-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 46px;
      margin-top: 18px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 999px;
      padding: 0 18px;
      text-decoration: none;
      font-family: var(--font-mono);
      font-size: 0.74rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      transition: background 0.25s ease, transform 0.25s ease, border-color 0.25s ease;
    }

    .project-link:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 255, 255, 0.28);
      transform: translateY(-2px);
    }

    .timeline-shell {
      position: relative;
      margin-top: 40px;
      padding: 12px 0;
    }

    .timeline-line {
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 1px;
      background: rgba(255, 255, 255, 0.1);
      transform: translateX(-50%);
    }

    .timeline-entry {
      position: relative;
      width: calc(50% - 44px);
      margin: 0 0 48px;
      padding: 22px 24px;
      border-radius: 22px;
    }

    .timeline-entry.left {
      margin-right: auto;
    }

    .timeline-entry.right {
      margin-left: auto;
    }

    .timeline-entry::before {
      content: "";
      position: absolute;
      top: 28px;
      width: 14px;
      height: 14px;
      border-radius: 999px;
      background: #ffffff;
      box-shadow: 0 0 0 6px rgba(255, 255, 255, 0.06);
    }

    .timeline-entry.left::before {
      right: -52px;
    }

    .timeline-entry.right::before {
      left: -52px;
    }

    .timeline-entry h3,
    .education-card h3 {
      margin: 0 0 10px;
      font-size: 1.2rem;
      text-transform: uppercase;
      letter-spacing: -0.03em;
    }

    .timeline-company {
      margin: 0 0 10px;
      color: var(--muted);
      font-size: 0.95rem;
    }

    .timeline-range {
      display: inline-flex;
      margin-bottom: 18px;
      font-size: 0.68rem;
      color: var(--muted-soft);
    }

    .timeline-entry ul {
      margin: 0;
      padding-left: 18px;
      color: var(--muted);
      line-height: 1.9;
    }

    .education-grid {
      margin-top: 34px;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 22px;
    }

    .education-card {
      border-radius: 22px;
      padding: 26px;
      transition: transform 0.18s ease;
    }

    .education-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.8;
    }

    .contact {
      overflow: hidden;
      border-radius: 28px 28px 0 0;
      margin-top: 60px;
      padding-bottom: 110px;
    }

    .contact-shell {
      position: relative;
      z-index: 2;
      width: var(--content-width);
      margin: 0 auto;
      padding: 120px 0 0;
      text-align: center;
    }

    .contact h2 {
      margin: 0 0 18px;
      font-size: clamp(2.4rem, 5vw, 4.8rem);
      line-height: 0.92;
      letter-spacing: -0.06em;
      text-transform: uppercase;
    }

    .contact p {
      margin: 0 auto;
      max-width: 620px;
      color: var(--muted);
      line-height: 1.8;
    }

    .contact-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 58px;
      margin-top: 34px;
      padding: 0 28px;
      border: 1px solid rgba(255, 255, 255, 0.24);
      border-radius: 999px;
      background: transparent;
      text-decoration: none;
      font-family: var(--font-mono);
      font-size: 0.74rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      transition: background 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
    }

    .contact-cta:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 255, 255, 0.34);
      transform: translateY(-2px);
    }

    .contact-links {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 18px;
      margin-top: 28px;
    }

    .contact-links a {
      text-decoration: none;
      color: var(--muted);
      font-size: 0.72rem;
    }

    .footer {
      width: var(--content-width);
      margin: 0 auto;
      padding: 26px 0 48px;
      color: var(--muted-soft);
      font-size: 0.68rem;
      text-align: center;
    }

    @media (max-width: 1024px) {
      .section-nav {
        display: none;
      }

      .projects-grid {
        grid-template-columns: 1fr;
      }

      .timeline-line {
        left: 16px;
        transform: none;
      }

      .timeline-entry,
      .timeline-entry.left,
      .timeline-entry.right {
        width: calc(100% - 44px);
        margin-left: 44px;
        margin-right: 0;
      }

      .timeline-entry::before,
      .timeline-entry.left::before,
      .timeline-entry.right::before {
        left: -35px;
        right: auto;
      }
    }

    @media (max-width: 820px) {
      .section {
        width: min(100vw - 34px, 1180px);
        padding: 94px 0;
      }

      .about {
        grid-template-columns: 1fr;
        padding: 34px 24px;
        gap: 30px;
      }

      .contact-shell,
      .hero-overlay,
      .footer {
        width: min(100vw - 34px, 1180px);
      }
    }

    @media (max-width: 640px) {
      .hero-overlay {
        padding-top: 90px;
      }

      .hero-role {
        font-size: 0.8rem;
      }

      .project-card {
        height: 380px;
      }

      .card-front-overlay h3 {
        font-size: 1.1rem;
      }

      .contact {
        border-radius: 22px 22px 0 0;
      }
    }

    {{{customCss}}}

    /* Safety overrides after custom CSS */
    body,
    .page {
      background-color: #000000 !important;
      color: #ffffff !important;
    }

    .hero {
      mix-blend-mode: normal !important;
      isolation: isolate;
    }

    .hero-overlay {
      position: relative;
      z-index: 10;
      color: #ffffff !important;
    }

    .hero-label,
    .hero-name,
    .hero-role,
    .hero-scroll-hint {
      color: #ffffff !important;
      -webkit-text-fill-color: #ffffff !important;
    }

    .hero-name {
      text-shadow: none !important;
      mix-blend-mode: normal !important;
    }

    #hero-canvas {
      position: fixed !important;
      top: 0;
      left: 0;
      z-index: 0 !important;
      pointer-events: none !important;
    }

    .about {
      background: #0a0a0a !important;
      color: #ffffff !important;
    }

    .about .meta-chip {
      color: #ffffff !important;
      border-color: rgba(255, 255, 255, 0.2) !important;
      background: rgba(255, 255, 255, 0.04) !important;
    }

    .about-bio {
      overflow: visible !important;
      max-height: none !important;
      height: auto !important;
    }

    .skills-grid,
    .badge {
      position: relative;
      z-index: 10;
    }

    .badge {
      color: #ffffff !important;
      -webkit-text-fill-color: #ffffff !important;
      opacity: 1 !important;
      visibility: visible !important;
    }

    #projects .project-display-title {
      color: rgba(255, 255, 255, 0.06) !important;
      -webkit-text-fill-color: rgba(255, 255, 255, 0.06) !important;
    }

    .card-front-overlay h3,
    .card-back,
    .card-back * {
      color: #ffffff !important;
      -webkit-text-fill-color: #ffffff !important;
    }
  </style>
</head>
<body data-portfolio-id="{{portfolioId}}">
  <div id="scroll-progress" aria-hidden="true"></div>
  <div id="cursor" aria-hidden="true"></div>

  <nav class="section-nav" aria-label="Section navigation">
    <a href="#hero" data-section="hero" class="active"><span class="nav-dot"></span><span>Hero</span></a>
    <a href="#about" data-section="about"><span class="nav-dot"></span><span>About</span></a>
    {{#if hasSkills}}<a href="#skills" data-section="skills"><span class="nav-dot"></span><span>Skills</span></a>{{/if}}
    {{#if hasProjects}}<a href="#projects" data-section="projects"><span class="nav-dot"></span><span>Projects</span></a>{{/if}}
    {{#if hasExperience}}<a href="#experience" data-section="experience"><span class="nav-dot"></span><span>Experience</span></a>{{/if}}
    {{#if hasEducation}}<a href="#education" data-section="education"><span class="nav-dot"></span><span>Education</span></a>{{/if}}
    <a href="#contact" data-section="contact"><span class="nav-dot"></span><span>Contact</span></a>
  </nav>

  <div class="page">
    <section class="hero" id="hero">
      <canvas id="hero-canvas" aria-hidden="true"></canvas>
      <div class="hero-overlay">
        <p class="hero-label">{{heroLabel}}</p>
        <h1 class="hero-name">{{name}}</h1>
        <p class="hero-role">{{tagline}}</p>
        <div class="hero-scroll-hint">{{{scrollHint}}}</div>
      </div>
    </section>

    <section class="section" id="about">
      <div class="section-shell about panel">
        <canvas class="section-particles" id="about-canvas" aria-hidden="true"></canvas>
        <div class="about-avatar-frame">
          <img class="about-avatar" src="{{avatarImage}}" alt="{{avatarAlt}}" loading="lazy" decoding="async" />
        </div>
        <div class="about-text">
          <span class="section-kicker">About</span>
          <h2 class="section-title">{{title}}</h2>
          <p class="section-intro about-bio">{{bio}}</p>
          <div class="about-meta">
            {{#if hasLocation}}<span class="meta-chip">{{location}}</span>{{/if}}
            {{#if hasEmail}}<span class="meta-chip">{{email}}</span>{{/if}}
            {{#if hasPhone}}<span class="meta-chip">{{phone}}</span>{{/if}}
          </div>
        </div>
      </div>
    </section>

    {{#if hasSkills}}
    <section class="section skills-section" id="skills">
      <div class="section-shell">
        <span class="section-kicker">Skills</span>
        <h2 class="section-title">Floating Capability Cloud</h2>
        <p class="section-intro">Core tools and systems that shape the work. Hover to focus, tap to inspect.</p>
        <div class="skills-grid" id="skills-grid">
          {{#each skills}}
          <button class="badge" type="button" data-tooltip="{{tooltip}}" data-level="{{levelLabel}}">
            {{name}}
          </button>
          {{/each}}
        </div>
        <div id="skill-tooltip" aria-live="polite"></div>
      </div>
    </section>
    {{/if}}

    {{#if hasProjects}}
    <section class="section" id="projects">
      <div class="section-shell">
        <span class="section-kicker">Projects</span>
        <h2 class="section-title">Selected Work</h2>
        <p class="section-intro">Projects arrive as tactile objects: tilt them, flip them, and inspect the stack.</p>
        <div class="projects-grid">
          {{#each projects}}
          <article class="project-card">
            <div class="card-inner">
              <div class="card-face card-front">
                {{#if hasPreviewImage}}
                <img src="{{previewImage}}" alt="{{title}}" loading="lazy" decoding="async" />
                {{else}}
                <div class="project-fallback" aria-hidden="true">
                  <span>Project</span>
                </div>
                {{/if}}
                <div class="project-display-title" aria-hidden="true">{{title}}</div>
                <div class="card-front-overlay">
                  <h3>{{title}}</h3>
                </div>
              </div>
              <div class="card-face card-back">
                <div>
                  <h4>Project Overview</h4>
                  <p>{{description}}</p>
                  {{#if hasTechStack}}
                  <div class="project-tech">
                    {{#each techStack}}
                    <span>{{this}}</span>
                    {{/each}}
                  </div>
                  {{/if}}
                </div>
                {{#if hasProjectUrl}}
                <a class="project-link" href="{{projectUrl}}" target="_blank" rel="noreferrer">Visit Project -&gt;</a>
                {{/if}}
              </div>
            </div>
          </article>
          {{/each}}
        </div>
      </div>
    </section>
    {{/if}}

    {{#if hasExperience}}
    <section class="section" id="experience">
      <div class="section-shell">
        <span class="section-kicker">Experience</span>
        <h2 class="section-title">Animated Timeline</h2>
        <p class="section-intro">A concise path through the roles, systems, and responsibilities that built the portfolio.</p>
        <div class="timeline-shell">
          <div class="timeline-line"></div>
          {{#each experience}}
          <article class="timeline-entry panel {{side}}">
            <h3>{{role}}</h3>
            <p class="timeline-company">{{company}}</p>
            <span class="timeline-range">{{dateRange}}</span>
            <ul>
              {{#each bullets}}
              <li>{{this}}</li>
              {{/each}}
            </ul>
          </article>
          {{/each}}
        </div>
      </div>
    </section>
    {{/if}}

    {{#if hasEducation}}
    <section class="section" id="education">
      <div class="section-shell">
        <span class="section-kicker">Education</span>
        <h2 class="section-title">Foundation</h2>
        <p class="section-intro">Academic grounding presented as compact cards with the same tactile motion language.</p>
        <div class="education-grid">
          {{#each education}}
          <article class="education-card panel tilt-card">
            <h3>{{degree}}</h3>
            <p>{{institution}}{{#if year}} | {{year}}{{/if}}</p>
          </article>
          {{/each}}
        </div>
      </div>
    </section>
    {{/if}}

    <section class="section contact panel" id="contact">
      <canvas class="section-particles" id="contact-canvas" aria-hidden="true"></canvas>
      <div class="contact-shell">
        <span class="section-kicker">Contact</span>
        <h2>Let's Work Together</h2>
        <p>Open to thoughtful collaborations, ambitious products, and teams that care about craft as much as outcomes.</p>
        {{#if hasEmail}}
        <a class="contact-cta" href="mailto:{{email}}">Email {{name}}</a>
        {{/if}}
        {{#if hasSocialLinks}}
        <div class="contact-links">
          {{#each socialLinks}}
          <a href="{{href}}" target="_blank" rel="noreferrer">{{label}}</a>
          {{/each}}
        </div>
        {{/if}}
      </div>
    </section>

    <footer class="footer">Built with Portify | {{year}}</footer>
  </div>
  <script>
    (() => {
      const body = document.body;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const finePointer = window.matchMedia('(pointer: fine)').matches;
      const mobile = window.matchMedia('(max-width: 768px)').matches;
      const progressBar = document.getElementById('scroll-progress');
      const sectionLinks = Array.from(document.querySelectorAll('.section-nav a'));
      const sections = Array.from(document.querySelectorAll('section[id]'));
      const hoverables = Array.from(document.querySelectorAll('a, button, .project-card, .tilt-card'));
      const skillGrid = document.getElementById('skills-grid');
      const skillTooltip = document.getElementById('skill-tooltip');
      const visibilityState = { paused: document.visibilityState !== 'visible' };
      const loops = [];
      const cleanups = [];
      const resizeHandlers = [];
      let rafId = 0;

      if (finePointer) {
        body.classList.add('cursor-enabled');
      }

      function registerLoop(loop) {
        loops.push(loop);
      }

      function registerCleanup(cleanup) {
        cleanups.push(cleanup);
      }

      function registerResize(handler) {
        resizeHandlers.push(handler);
      }

      function animate(now) {
        if (visibilityState.paused) {
          rafId = 0;
          return;
        }
        for (const loop of loops) {
          loop(now || performance.now());
        }
        rafId = window.requestAnimationFrame(animate);
      }

      function ensureLoop() {
        if (!rafId) {
          rafId = window.requestAnimationFrame(animate);
        }
      }

      function clamp(value, min, max) {
        return Math.max(min, Math.min(max, value));
      }

      function updateProgress() {
        const scrollable = document.documentElement.scrollHeight - window.innerHeight;
        const pct = scrollable > 0 ? window.scrollY / scrollable : 0;
        progressBar.style.width = `${pct * 100}%`;
      }

      function initCursor() {
        const cursor = document.getElementById('cursor');
        if (!cursor || !finePointer) {
          return;
        }

        let cx = window.innerWidth / 2;
        let cy = window.innerHeight / 2;
        let tx = cx;
        let ty = cy;

        document.addEventListener('mousemove', (event) => {
          tx = event.clientX;
          ty = event.clientY;
          cursor.style.opacity = '1';
        }, { passive: true });

        registerLoop(() => {
          cx += (tx - cx) * 0.12;
          cy += (ty - cy) * 0.12;
          cursor.style.left = `${cx}px`;
          cursor.style.top = `${cy}px`;
        });

        hoverables.forEach((element) => {
          element.addEventListener('mouseenter', () => cursor.classList.add('active'));
          element.addEventListener('mouseleave', () => cursor.classList.remove('active'));
        });
      }

      function createAmbientScene(canvasId, particleCount) {
        const canvas = document.getElementById(canvasId);
        if (!canvas || !window.THREE) {
          return;
        }

        const section = canvas.parentElement;
        const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.5));
        renderer.setClearColor(0x000000, 0);

        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(60, 1, 0.1, 100);
        camera.position.z = 6;

        const geometry = new THREE.BufferGeometry();
        const positions = new Float32Array(particleCount * 3);
        const velocities = new Float32Array(particleCount * 3);

        for (let i = 0; i < particleCount; i += 1) {
          const index = i * 3;
          positions[index] = (Math.random() - 0.5) * 10;
          positions[index + 1] = (Math.random() - 0.5) * 6;
          positions[index + 2] = (Math.random() - 0.5) * 3;
          velocities[index] = (Math.random() - 0.5) * 0.0012;
          velocities[index + 1] = (Math.random() - 0.5) * 0.0009;
          velocities[index + 2] = (Math.random() - 0.5) * 0.0005;
        }

        geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        const material = new THREE.PointsMaterial({
          color: 0xffffff,
          size: 0.03,
          transparent: true,
          opacity: 0.22,
        });
        const points = new THREE.Points(geometry, material);
        scene.add(points);

        function resize() {
          const width = section.clientWidth;
          const height = section.clientHeight;
          renderer.setSize(width, height, false);
          camera.aspect = width / Math.max(height, 1);
          camera.updateProjectionMatrix();
        }

        registerResize(resize);
        resize();

        registerLoop(() => {
          const attribute = geometry.attributes.position;
          for (let i = 0; i < particleCount; i += 1) {
            const index = i * 3;
            positions[index] += velocities[index];
            positions[index + 1] += velocities[index + 1];
            positions[index + 2] += velocities[index + 2];

            if (positions[index] > 5 || positions[index] < -5) velocities[index] *= -1;
            if (positions[index + 1] > 3 || positions[index + 1] < -3) velocities[index + 1] *= -1;
            if (positions[index + 2] > 2 || positions[index + 2] < -2) velocities[index + 2] *= -1;
          }
          attribute.needsUpdate = true;
          renderer.render(scene, camera);
        });

        registerCleanup(() => {
          geometry.dispose();
          material.dispose();
          renderer.dispose();
        });
      }

      function createHeroScene() {
        const canvas = document.getElementById('hero-canvas');
        if (!canvas || !window.THREE) {
          return;
        }

        const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.5));
        renderer.setClearColor(0x000000, 1);

        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, 1, 0.1, 1000);
        camera.position.z = 7.2;

        const particleCount = mobile ? 800 : 3000;
        const geometry = new THREE.BufferGeometry();
        const positions = new Float32Array(particleCount * 3);
        const velocities = new Float32Array(particleCount * 3);

        for (let i = 0; i < particleCount; i += 1) {
          const index = i * 3;
          positions[index] = (Math.random() - 0.5) * 10;
          positions[index + 1] = (Math.random() - 0.5) * 7;
          positions[index + 2] = (Math.random() - 0.5) * 8;
          velocities[index] = (Math.random() - 0.5) * 0.0002;
          velocities[index + 1] = (Math.random() - 0.5) * 0.0001;
          velocities[index + 2] = (Math.random() - 0.5) * 0.00015;
        }

        geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        const particles = new THREE.Points(
          geometry,
          new THREE.PointsMaterial({
            color: 0xffffff,
            size: mobile ? 0.02 : 0.012,
            transparent: true,
            opacity: 0.6,
          }),
        );
        scene.add(particles);

        const wireframeMaterial = new THREE.MeshBasicMaterial({
          color: 0xffffff,
          wireframe: true,
          opacity: 0.06,
          transparent: true,
        });
        const wireframe = new THREE.Mesh(new THREE.IcosahedronGeometry(2.5, 1), wireframeMaterial);
        scene.add(wireframe);

        const orbiters = [];
        for (let i = 0; i < 6; i += 1) {
          const sphere = new THREE.Mesh(
            new THREE.SphereGeometry(0.04, 24, 24),
            new THREE.MeshBasicMaterial({ color: 0xffffff }),
          );
          scene.add(sphere);
          orbiters.push({
            sphere,
            radius: 1.5 + (i * 0.22),
            speed: 0.35 + (i * 0.09),
            tiltX: (i + 1) * 0.5,
            tiltY: 0.5 + (i * 0.2),
            phase: i * Math.PI / 3,
          });
        }

        const mouse = { x: 999, y: 999 };

        document.addEventListener('mousemove', (event) => {
          const nx = (event.clientX / window.innerWidth) * 2 - 1;
          const ny = -(event.clientY / window.innerHeight) * 2 + 1;
          const distance = camera.position.z;
          mouse.x = nx * (camera.aspect * distance * Math.tan((camera.fov * Math.PI) / 360));
          mouse.y = ny * (distance * Math.tan((camera.fov * Math.PI) / 360));
        }, { passive: true });

        function resize() {
          const width = window.innerWidth;
          const height = window.innerHeight;
          renderer.setSize(width, height, false);
          camera.aspect = width / Math.max(height, 1);
          camera.updateProjectionMatrix();
        }

        registerResize(resize);
        resize();

        gsap.to(camera.position, { z: 5, duration: 2.6, ease: 'power4.out' });

        registerLoop((now) => {
          const time = now * 0.001;
          const attribute = geometry.attributes.position;

          wireframe.rotation.x += 0.001;
          wireframe.rotation.y += 0.0015;

          const heroProgress = clamp(window.scrollY / Math.max(window.innerHeight, 1), 0, 1);
          const shrink = 1 - (heroProgress * 0.9);
          wireframe.scale.setScalar(Math.max(shrink, 0.04));
          wireframeMaterial.opacity = 0.06 * (1 - heroProgress);

          for (let i = 0; i < particleCount; i += 1) {
            const index = i * 3;
            positions[index] += velocities[index];
            positions[index + 1] += velocities[index + 1];
            positions[index + 2] += velocities[index + 2];

            const dx = positions[index] - mouse.x;
            const dy = positions[index + 1] - mouse.y;
            const distance = Math.sqrt((dx * dx) + (dy * dy));
            if (distance < 1.5) {
              const force = (1.5 - distance) / 1.5;
              const angle = Math.atan2(dy, dx);
              positions[index] += Math.cos(angle) * force * 0.03;
              positions[index + 1] += Math.sin(angle) * force * 0.03;
            }

            if (positions[index] > 5 || positions[index] < -5) velocities[index] *= -1;
            if (positions[index + 1] > 3.6 || positions[index + 1] < -3.6) velocities[index + 1] *= -1;
            if (positions[index + 2] > 4 || positions[index + 2] < -4) velocities[index + 2] *= -1;
          }

          attribute.needsUpdate = true;

          orbiters.forEach((orbiter, index) => {
            const angle = time * orbiter.speed + orbiter.phase;
            orbiter.sphere.position.set(
              Math.cos(angle) * orbiter.radius,
              Math.sin(angle * orbiter.tiltX) * (orbiter.radius * 0.45),
              Math.sin(angle * orbiter.tiltY) * orbiter.radius,
            );
            orbiter.sphere.scale.setScalar(1 - (heroProgress * (0.15 + (index * 0.02))));
          });

          renderer.render(scene, camera);
        });

        registerCleanup(() => {
          geometry.dispose();
          particles.material.dispose();
          wireframe.geometry.dispose();
          wireframeMaterial.dispose();
          orbiters.forEach((orbiter) => {
            orbiter.sphere.geometry.dispose();
            orbiter.sphere.material.dispose();
          });
          renderer.dispose();
        });
      }

      function initTilt(element) {
        if (!finePointer) {
          return;
        }

        element.addEventListener('mousemove', (event) => {
          const rect = element.getBoundingClientRect();
          const x = (event.clientX - rect.left) / rect.width - 0.5;
          const y = (event.clientY - rect.top) / rect.height - 0.5;
          element.style.transform = `perspective(1000px) rotateX(${-y * 12}deg) rotateY(${x * 12}deg)`;
        });

        element.addEventListener('mouseleave', () => {
          element.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg)';
        });
      }

      function initProjectCards() {
        document.querySelectorAll('.project-card').forEach((card) => {
          initTilt(card);
          card.addEventListener('click', (event) => {
            if (event.target.closest('a')) {
              return;
            }
            card.classList.toggle('flipped');
          });
        });

        document.querySelectorAll('.tilt-card').forEach((card) => {
          initTilt(card);
        });
      }

      function initSkillCloud() {
        if (!skillGrid || !skillTooltip) {
          return;
        }

        const badges = Array.from(skillGrid.querySelectorAll('.badge'));
        badges.forEach((badge) => {
          badge.addEventListener('mouseenter', () => {
            skillGrid.classList.add('dimmed');
            badges.forEach((item) => item.classList.remove('active'));
            badge.classList.add('active');
            skillTooltip.textContent = badge.getAttribute('data-tooltip') || '';
          });

          badge.addEventListener('mouseleave', () => {
            skillGrid.classList.remove('dimmed');
            badge.classList.remove('active');
            skillTooltip.textContent = '';
          });

          badge.addEventListener('click', () => {
            skillTooltip.textContent = badge.getAttribute('data-tooltip') || '';
          });
        });

        if (!prefersReducedMotion) {
          registerLoop((now) => {
            const time = now * 0.0002;
            badges.forEach((badge, index) => {
              const x = Math.sin(time + index) * 4;
              const y = Math.cos((time * 1.4) + index) * 4;
              badge.style.transform = badge.classList.contains('active')
                ? 'scale(1.12) translateZ(22px)'
                : `translate3d(${x}px, ${y}px, 0)`;
            });
          });
        }
      }

      function initSectionNav() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) {
              return;
            }

            const id = entry.target.getAttribute('id');
            sectionLinks.forEach((link) => {
              link.classList.toggle('active', link.getAttribute('data-section') === id);
            });
          });
        }, { threshold: 0.55 });

        sections.forEach((section) => observer.observe(section));
        registerCleanup(() => observer.disconnect());
      }

      function initAnalytics() {
        const portfolioId = body.getAttribute('data-portfolio-id');
        if (!portfolioId || !window.location.protocol.startsWith('http')) {
          return;
        }

        const sessionStorageKey = `portify-session-${portfolioId}`;
        let sessionId = window.localStorage.getItem(sessionStorageKey);
        if (!sessionId) {
          sessionId = `${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
          window.localStorage.setItem(sessionStorageKey, sessionId);
        }

        const analyticsRoot = `${window.location.origin}/api/analytics`;

        function send(path, payload, useBeacon) {
          const bodyPayload = JSON.stringify(payload);
          const url = `${analyticsRoot}/${path}`;
          if (useBeacon && navigator.sendBeacon) {
            const blob = new Blob([bodyPayload], { type: 'application/json' });
            navigator.sendBeacon(url, blob);
            return;
          }

          fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: bodyPayload,
            keepalive: true,
          }).catch(() => {});
        }

        send('pageview', {
          portfolioId,
          referrer: document.referrer,
          sessionId,
          userAgent: navigator.userAgent,
          timestamp: new Date().toISOString(),
        }, false);

        const sectionStarts = new Map();
        const sectionObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            const id = entry.target.getAttribute('id');
            if (!id) {
              return;
            }

            if (entry.isIntersecting) {
              sectionStarts.set(id, performance.now());
              return;
            }

            if (!sectionStarts.has(id)) {
              return;
            }

            const startedAt = sectionStarts.get(id);
            sectionStarts.delete(id);
            send('section-view', {
              portfolioId,
              section: id,
              timeSpentMs: Math.round(performance.now() - startedAt),
              sessionId,
            }, false);
          });
        }, { threshold: 0.45 });

        sections.forEach((section) => sectionObserver.observe(section));
        window.addEventListener('beforeunload', () => {
          sectionStarts.forEach((startedAt, id) => {
            send('section-view', {
              portfolioId,
              section: id,
              timeSpentMs: Math.round(performance.now() - startedAt),
              sessionId,
            }, true);
          });
        });

        registerCleanup(() => sectionObserver.disconnect());
      }

      function initAnimations() {
        gsap.registerPlugin(ScrollTrigger);
        gsap.from('.page', { opacity: 0, duration: 1.1, ease: 'power2.out' });
        gsap.from('.hero-label', { opacity: 0, y: -20, duration: 1, delay: 0.5 });
        gsap.from('.hero-name', { opacity: 0, y: 40, duration: 1.2, delay: 0.8 });
        gsap.from('.hero-role', { opacity: 0, y: 20, duration: 1, delay: 1.2 });

        gsap.from('.about-avatar', {
          scrollTrigger: { trigger: '.about', start: 'top 80%', once: true },
          x: -80,
          opacity: 0,
          duration: 1.2,
          ease: 'power3.out',
        });

        gsap.from('.about-text', {
          scrollTrigger: { trigger: '.about', start: 'top 75%', once: true },
          x: 80,
          opacity: 0,
          duration: 1.2,
          ease: 'power3.out',
        });

        if (document.querySelectorAll('.badge').length) {
          gsap.from('.badge', {
            scrollTrigger: { trigger: '#skills', start: 'top 80%', once: true },
            scale: 0,
            opacity: 0,
            duration: 0.4,
            stagger: { amount: 0.8, from: 'random' },
            ease: 'back.out(1.7)',
          });
        }

        if (document.querySelectorAll('.project-card').length) {
          gsap.from('.project-card', {
            scrollTrigger: { trigger: '#projects', start: 'top 75%', once: true },
            y: 60,
            opacity: 0,
            duration: 0.8,
            stagger: 0.15,
            ease: 'power3.out',
          });
        }

        document.querySelectorAll('.timeline-entry').forEach((entry, index) => {
          gsap.from(entry, {
            scrollTrigger: { trigger: entry, start: 'top 85%', once: true },
            x: index % 2 === 0 ? -60 : 60,
            opacity: 0,
            duration: 0.9,
            ease: 'power3.out',
          });
        });

        if (document.querySelector('.timeline-line')) {
          gsap.from('.timeline-line', {
            scrollTrigger: {
              trigger: '#experience',
              start: 'top center',
              end: 'bottom center',
              scrub: true,
            },
            scaleY: 0,
            transformOrigin: 'top center',
          });
        }

        if (document.querySelectorAll('.education-card').length) {
          gsap.from('.education-card', {
            scrollTrigger: { trigger: '#education', start: 'top 80%', once: true },
            y: 34,
            opacity: 0,
            duration: 0.75,
            stagger: 0.12,
            ease: 'power3.out',
          });
        }

        if (document.querySelector('.contact h2')) {
          gsap.from('.contact h2', {
            scrollTrigger: { trigger: '#contact', start: 'top 80%', once: true },
            scale: 0.8,
            opacity: 0,
            duration: 1.2,
            ease: 'power4.out',
          });
        }

        ScrollTrigger.refresh();
      }

      document.addEventListener('visibilitychange', () => {
        visibilityState.paused = document.visibilityState !== 'visible';
        if (!visibilityState.paused) {
          ensureLoop();
        }
      });

      window.addEventListener('resize', () => {
        resizeHandlers.forEach((handler) => handler());
        updateProgress();
      });
      window.addEventListener('scroll', updateProgress, { passive: true });

      updateProgress();
      initCursor();
      createHeroScene();
      createAmbientScene('about-canvas', mobile ? 120 : 220);
      createAmbientScene('contact-canvas', mobile ? 100 : 180);
      initProjectCards();
      initSkillCloud();
      initSectionNav();
      initAnalytics();
      initAnimations();
      ensureLoop();

      window.addEventListener('unload', () => {
        cleanups.forEach((cleanup) => cleanup());
      });
    })();
  </script>
</body>
</html>
